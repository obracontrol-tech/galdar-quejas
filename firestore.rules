rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /quejas/{quejaId} {
      // Cualquier vecino puede crear una queja
      allow create: if request.resource.data.keys().hasAll(['barrio','categoria','descripcion','estado','fecha'])
                    && request.resource.data.estado == 'nueva';
      // Solo lectura y edición de estado (sin borrar) — se controla por contraseña en la app
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado']);
    }
  }
}
